# ─────────────────────────────────────────────────────────────
# OpenRemap — environment variable reference
# Copy this file to .env and fill in the values before starting
# the API server.  The CLI never reads this file.
# ─────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────
APP_NAME=openremap

# "development" or "production"
# production raises the log threshold and enables stricter checks.
APP_ENV=development

# ── MongoDB ───────────────────────────────────────────────────
# Required for recipe storage and lookup.
# Leave blank to run without a database (tuning pipeline still works).
MONGO_URL=mongodb://localhost:27017

# ── Redis ─────────────────────────────────────────────────────
# Optional.  When REDIS_ENABLED=true the rate limiter uses Redis
# for persistent counters shared across workers.
# When false, an in-process memory store is used instead.
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# Time-to-live in seconds for cached values (default: 300 = 5 min).
CACHE_TTL=300

# ── Auth tokens ───────────────────────────────────────────────
# Required when authentication endpoints are enabled.
# Generate a strong secret with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-random-secret

# Token expiry in seconds (0 = never expire — not recommended for production).
ACCESS_TOKEN_EXPIRY=3600
REFRESH_TOKEN_EXPIRY=86400

# ── CORS ──────────────────────────────────────────────────────
# JSON list of allowed frontend origins.
# Add your dashboard URL here when deploying.
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
