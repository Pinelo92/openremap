# ── Python generated ─────────────────────────────────────────────────────────
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info/
.pytest_cache/

# ── Virtual environment ───────────────────────────────────────────────────────
.venv/

# ── Environment variables — never commit secrets ──────────────────────────────
.env
.env.*
!server/.env.example

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ── ECU binary files — never commit real ECU binaries ────────────────────────
*.bin
*.ori
*.BIN
*.ORI

# Allow the public sample binary used for testing
!core/public/original.bin

# ── Legacy code (reference only, not part of any package) ────────────────────
src/legacy/

# ── Personal notes and to-do lists ───────────────────────────────────────────
todo/
